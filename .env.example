OPENAI_API_KEY=여기에_OpenAI_API_키를_입력하세요

# 이메일 전송 (Gmail 사용 시)
# Gmail 앱 비밀번호 발급: 구글계정 → 보안 → 2단계인증 → 앱 비밀번호
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16digit_app_password

# 문자(SMS) 전송 — coolsms.co.kr 가입 후 발급
COOLSMS_API_KEY=your_coolsms_api_key
COOLSMS_API_SECRET=your_coolsms_api_secret
COOLSMS_FROM_NUMBER=01012345678
